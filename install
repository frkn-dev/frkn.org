#!/bin/bash

set -e

exec < /dev/tty

# Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Функции для вывода
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_header() {
    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo ""
}

print_protocol() {
    echo -e "${CYAN}🔧 $1${NC}"
}

# Проверка прав root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "Этот скрипт должен запускаться от root пользователя!"
        echo "Используйте: sudo bash $0"
        exit 1
    fi
}

# Проверка ОС
check_os() {
    if [[ ! -f /etc/os-release ]]; then
        print_error "Не удалось определить ОС"
        exit 1
    fi

    source /etc/os-release
    print_info "ОС: $NAME $VERSION"
}

# Установка зависимостей
install_dependencies() {
    print_info "Установка необходимых пакетов..."

    if command -v apt-get &> /dev/null; then
        apt-get update
        apt-get install -y curl unzip uuid-runtime jq openssl
    elif command -v yum &> /dev/null; then
        yum install -y curl unzip uuidgen jq openssl
    elif command -v dnf &> /dev/null; then
        dnf install -y curl unzip uuidgen jq openssl
    else
        print_error "Не удалось определить менеджер пакетов"
        exit 1
    fi
}

# Генерация UUID
generate_uuid() {
    echo $(uuidgen | tr '[:upper:]' '[:lower:]')
}

# Генерация ключей Xray Reality (без вывода лишних сообщений)
generate_reality_keys() {
    local PRIVATE_KEY=""
    local PUBLIC_KEY=""

    # Пробуем использовать xray из установленной директории
    if [[ -f "/opt/xray/xray" ]]; then
        # Генерируем ключи через xray
        local XRAY_OUTPUT=$(/opt/xray/xray x25519 2>/dev/null)
        PRIVATE_KEY=$(echo "$XRAY_OUTPUT" | grep "Private key:" | awk '{print $3}')
        PUBLIC_KEY=$(echo "$XRAY_OUTPUT" | grep "Public key:" | awk '{print $3}')
    fi

    # Если xray не сработал или не выдал ключи, используем openssl
    if [[ -z "$PRIVATE_KEY" || -z "$PUBLIC_KEY" ]]; then
        PRIVATE_KEY=$(openssl rand -base64 32 | tr -d '\n')
        PUBLIC_KEY=$(openssl rand -base64 32 | tr -d '\n')
    fi

    # Генерация shortId
    SHORT_ID=$(openssl rand -hex 8)

    echo "$PRIVATE_KEY|$PUBLIC_KEY|$SHORT_ID"
}

# Функция установки Xray с конфигом
install_xray() {
    print_header "Установка Xray-core с генерацией конфига"

    INSTALL_DIR="/opt/xray"

    XRAY_VERSION="${XRAY_VERSION:-v26.3.27}"
    
    print_info "Xray будет установлен в: $INSTALL_DIR"

    # Проверяем установлен ли уже xray
    if [[ -f "$INSTALL_DIR/xray" ]]; then
        print_warning "Xray уже установлен. Переустановить? (y/N): "
        read reinstall
        if [[ ! "$reinstall" =~ ^[Yy] ]]; then
            print_info "Пропускаем установку Xray"
            return 0
        fi
    fi

    mkdir -p "$INSTALL_DIR"
    cd "$INSTALL_DIR"

    echo "Installing xray-core version $XRAY_VERSION..."
    XRAY_URL="https://github.com/XTLS/Xray-core/releases/download/$XRAY_VERSION/Xray-linux-64.zip"
    curl -L -o xray.zip "$XRAY_URL"
    unzip -o xray.zip -d "$INSTALL_DIR"
    rm xray.zip

    chmod +x $INSTALL_DIR/xray

    print_success "Xray установлен"
    $INSTALL_DIR/xray --version

    # Выбор протоколов для установки
    print_header "Настройка протоколов Xray"
    echo "Выберите протоколы для установки:"
    echo ""
    echo "1) VLESS + TCP + Reality"
    echo "2) VLESS + gRPC + Reality"
    echo "3) VLESS + XHTTP + Reality"
    echo "4) Установить все протоколы"
    echo "5) Пропустить настройку"
    echo ""
    read -p "Ваш выбор [1-5]: " protocol_choice

    if [[ "$protocol_choice" == "5" ]]; then
        print_warning "Создан пустой конфиг. Настройте вручную: $INSTALL_DIR/xray-config.json"
        cat > $INSTALL_DIR/xray-config.json <<EOF
{
    "log": {
        "loglevel": "debug"
    },
    "inbounds": [],
    "outbounds": [
        {
            "protocol": "freedom",
            "tag": "DIRECT"
        }
    ]
}
EOF
    else
        generate_xray_config "$protocol_choice"
    fi

    # Создание systemd сервиса
    cat <<EOF | tee /etc/systemd/system/xray.service > /dev/null
[Unit]
Description=Xray Core Service
After=network.target

[Service]
ExecStart=$INSTALL_DIR/xray run -config $INSTALL_DIR/xray-config.json
Restart=on-failure
RestartSec=5
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable xray

    print_success "Xray установлен и настроен!"
    echo ""
    print_info "Конфигурация сохранена в: $INSTALL_DIR/xray-config.json"
    echo ""
    print_info "Запустите командой: sudo systemctl start xray"
}

# Генерация конфига Xray
generate_xray_config() {
    local choice=$1
    INSTALL_DIR="/opt/xray"

    print_info "Генерация ключей Reality..."

    # Генерация ключей
    KEYS=$(generate_reality_keys)
    PRIVATE_KEY=$(echo $KEYS | cut -d'|' -f1)
    PUBLIC_KEY=$(echo $KEYS | cut -d'|' -f2)
    SHORT_ID=$(echo $KEYS | cut -d'|' -f3)

    print_success "Ключи сгенерированы!"
    echo -e "${CYAN}Private Key:${NC} $PRIVATE_KEY"
    echo -e "${CYAN}Public Key:${NC} $PUBLIC_KEY"
    echo -e "${CYAN}Short ID:${NC} $SHORT_ID"
    echo ""

    read -p "Введите serverNames (через запятую, например: mail.google.com,google.com): " SERVER_NAMES
    SERVER_NAMES=${SERVER_NAMES:-"mail.google.com"}

    read -p "Введите target (например: mail.google.com:443): " TARGET
    TARGET=${TARGET:-"mail.google.com:443"}

    # Преобразуем serverNames в массив JSON
    IFS=',' read -ra NAMES_ARRAY <<< "$SERVER_NAMES"
    SERVER_NAMES_JSON=""
    for name in "${NAMES_ARRAY[@]}"; do
        trimmed_name=$(echo "$name" | xargs)
        SERVER_NAMES_JSON="$SERVER_NAMES_JSON\"$trimmed_name\","
    done
    SERVER_NAMES_JSON="[${SERVER_NAMES_JSON%,}]"

    # Начинаем формирование конфига
    cat > $INSTALL_DIR/xray-config.json <<EOF
{
    "log": {
        "loglevel": "debug"
    },
    "inbounds": [
EOF

    # Добавляем выбранные протоколы
    port=8443
    added=0

    add_inbound() {
        local network=$1
        local port_offset=$2
        local extra_settings=""

        if [[ $added -gt 0 ]]; then
            echo "," >> $INSTALL_DIR/xray-config.json
        fi

        if [[ "$network" == "grpc" ]]; then
            extra_settings=",
            \"grpcSettings\": {
                \"serviceName\": \"grpc\"
            }"
        elif [[ "$network" == "xhttp" ]]; then
            extra_settings=",
            \"xhttpSettings\": {
                \"path\": \"/\"
            }"
        fi

        cat >> $INSTALL_DIR/xray-config.json <<EOF
        {
            "tag": "Vless${network^}Reality",
            "listen": "0.0.0.0",
            "port": $((port + port_offset)),
            "protocol": "vless",
            "settings": {
                "clients": [],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "$network",
                "security": "reality",
                "realitySettings": {
                    "xver": 0,
                    "target": "$TARGET",
                    "serverNames": $SERVER_NAMES_JSON,
                    "privateKey": "$PRIVATE_KEY",
                    "publicKey": "$PUBLIC_KEY",
                    "shortIds": ["$SHORT_ID"]
                }$extra_settings
            },
            "sniffing": {
                "enabled": true,
                "destOverride": ["http", "tls", "quic"]
            }
        }
EOF
        added=1
    }

    case $choice in
    1)
        add_inbound "tcp" 0
        ;;
    2)
        add_inbound "grpc" 0
        ;;
    3)
        add_inbound "xhttp" 0
        ;;
    4)
        add_inbound "tcp" 0
        add_inbound "grpc" 2
        add_inbound "xhttp" 3
        ;;
    esac

    # Добавляем остальную часть конфига
    cat >> $INSTALL_DIR/xray-config.json <<EOF
    ],
    "outbounds": [
        {
            "protocol": "freedom",
            "tag": "DIRECT"
        },
        {
            "protocol": "blackhole",
            "tag": "BLOCK"
        }
    ],
    "routing": {
        "rules": [
            {
                "ip": ["geoip:private"],
                "outboundTag": "BLOCK",
                "type": "field"
            },
            {
                "domain": ["geosite:private"],
                "outboundTag": "BLOCK",
                "type": "field"
            },
            {
                "protocol": ["bittorrent"],
                "outboundTag": "BLOCK",
                "type": "field"
            },
            {
                "type": "field",
                "network": "tcp,udp",
                "outboundTag": "DIRECT"
            }
        ]
    },
    "api": {
        "listen": "127.0.0.1:23456",
        "services": [
            "HandlerService",
            "StatsService",
            "LoggerService",
            "ReflectionService"
        ],
        "tag": "API"
    },
    "stats": {},
    "policy": {
        "levels": {
            "0": {
                "statsUserUplink": true,
                "statsUserDownlink": true,
                "statsUserOnline": true
            }
        },
        "system": {
            "statsInboundDownlink": true,
            "statsInboundUplink": true,
            "statsOutboundDownlink": true,
            "statsOutboundUplink": true
        }
    }
}
EOF

    print_success "Конфигурация Xray создана!"
    echo ""
    print_info "Информация для подключения:"
    echo -e "${CYAN}Публичный ключ Reality:${NC} $PUBLIC_KEY"
    echo -e "${CYAN}Short ID:${NC} $SHORT_ID"
    echo -e "${CYAN}Server Names:${NC} $SERVER_NAMES"
    echo ""
}

# Функция установки Hysteria2
install_hysteria() {
    print_header "Установка Hysteria2"

    INSTALL_DIR="/opt/hysteria"
    BIN_PATH="$INSTALL_DIR/hysteria"
    CONFIG_PATH="$INSTALL_DIR/config.yaml"

    print_info "Hysteria2 будет установлен в: $INSTALL_DIR"

    if [[ -f "$BIN_PATH" ]]; then
        print_warning "Hysteria2 уже установлен. Переустановить? (y/N): "
        read reinstall
        if [[ ! "$reinstall" =~ ^[Yy] ]]; then
            print_info "Пропускаем установку Hysteria2"
            return 0
        fi
    fi

    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) ARCH="amd64" ;;
        aarch64) ARCH="arm64" ;;
        armv7l) ARCH="armv7" ;;
    *)
        print_error "Unsupported architecture: $ARCH"
        exit 1
        ;;
    esac

    # Создание пользователя
    if ! id "hysteria" &>/dev/null; then
        useradd -r -s /bin/false -m -d /nonexistent hysteria
    fi

    mkdir -p $INSTALL_DIR

    echo "===> Downloading hysteria binary..."
    curl -L -o $BIN_PATH https://github.com/apernet/hysteria/releases/latest/download/hysteria-linux-$ARCH
    chmod +x $BIN_PATH

    # Генерация пароля для Hysteria
    HYSTERIA_PASSWORD=$(openssl rand -base64 32)

    read -p "Введите hostname для Hysteria (например: example.com): " HOSTNAME
    EMAIL="2pizza1063@gmail.com"

    echo "Выберите тип аутентификации:"
    echo "1) Password (пароль)"
    echo "2) HTTP (внешний API)"
    read -p "Ваш выбор [1-2]: " auth_choice

    cat > $CONFIG_PATH <<EOF
listen: :443

acme:
  domains:
    - $HOSTNAME
  email: $EMAIL

EOF

    if [[ "$auth_choice" == "1" ]]; then
        cat >> $CONFIG_PATH <<EOF
auth:
  type: password
  password: $HYSTERIA_PASSWORD

EOF
        print_success "Пароль сгенерирован: $HYSTERIA_PASSWORD"
        echo -e "${CYAN}Сохраните этот пароль для подключения!${NC}"
    else
        HTTP_AUTH_URL="https://api.frkn.org/auth"
        cat >> $CONFIG_PATH <<EOF
auth:
  type: http
  http:
    url: $HTTP_AUTH_URL

EOF
    fi

    cat >> $CONFIG_PATH <<EOF
masquerade:
  type: proxy
  proxy:
    url: https://www.microsoft.com/
    rewriteHost: true

bandwidth:
  up: 1 gbps
  down: 1 gbps

ignoreClientBandwidth: false

quic:
  initStreamReceiveWindow: 16777216
  maxStreamReceiveWindow: 33554432
  initConnReceiveWindow: 33554432
  maxConnReceiveWindow: 67108864
  maxIdleTimeout: 30s
  maxIncomingStreams: 1024
  disablePathMTUDiscovery: false
EOF

    chown -R hysteria:hysteria $INSTALL_DIR

    cat > /etc/systemd/system/hysteria.service <<EOF
[Unit]
Description=Hysteria 2 Service
After=network.target

[Service]
Type=simple
WorkingDirectory=$INSTALL_DIR
ExecStart=$BIN_PATH server -c $CONFIG_PATH
Restart=always
RestartSec=5
LimitNOFILE=1048576
User=hysteria
Group=hysteria
Environment=HYSTERIA_LOG_LEVEL=info
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE CAP_NET_RAW
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE CAP_NET_RAW
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable hysteria

    print_success "Hysteria2 установлен успешно!"
    echo ""
    echo -e "${CYAN}Информация для подключения:${NC}"
    echo "Hostname: $HOSTNAME"
    echo "Port: 443"
    if [[ "$auth_choice" == "1" ]]; then
        echo "Password: $HYSTERIA_PASSWORD"
    else
        echo "Auth type: HTTP API"
    fi
    echo ""
    print_info "Запустите командой: sudo systemctl start hysteria"
}

# Функция установки Fnode
# Функция установки Fnode
install_fnode() {
    print_header "Установка Fnode"

    FNODE_VERSION="${FNODE_VERSION:-v0.5.7-dev}"
    INSTALL_DIR="/opt/fnode"
    ARCH=$(uname -m)

    print_info "Fnode будет установлен в: $INSTALL_DIR"

    # Генерация UUID
    NODE_UUID=$(generate_uuid)
    print_info "Сгенерирован UUID для узла: $NODE_UUID"

    # Запрос параметров с дефолтными значениями
    echo ""
    echo -e "${CYAN}Настройка параметров узла:${NC}"
    echo ""

    read -p "Label (название узла) [🏴‍☠️ Great Britain]: " LABEL
    LABEL=${LABEL:-"🏴‍☠️ Great Britain"}

    read -p "Country код [GB]: " COUNTRY
    COUNTRY=${COUNTRY:-"GB"}

    read -p "Node type (common/gateway) [common]: " NODE_TYPE
    NODE_TYPE=${NODE_TYPE:-"common"}

    read -p "Max bandwidth bps (пропускная способность в бит/с) [200000000]: " MAX_BANDWIDTH_BPS
    MAX_BANDWIDTH_BPS=${MAX_BANDWIDTH_BPS:-200000000}

    # Преобразование для удобства чтения
    if [[ $MAX_BANDWIDTH_BPS -ge 1000000000 ]]; then
        BW_READABLE="$((MAX_BANDWIDTH_BPS / 1000000000)) Gbps"
    elif [[ $MAX_BANDWIDTH_BPS -ge 1000000 ]]; then
        BW_READABLE="$((MAX_BANDWIDTH_BPS / 1000000)) Mbps"
    else
        BW_READABLE="$((MAX_BANDWIDTH_BPS / 1000)) Kbps"
    fi

    echo ""
    print_info "Параметры узла:"
    echo -e "  ${CYAN}UUID:${NC} $NODE_UUID"
    echo -e "  ${CYAN}Label:${NC} $LABEL"
    echo -e "  ${CYAN}Country:${NC} $COUNTRY"
    echo -e "  ${CYAN}Type:${NC} $NODE_TYPE"
    echo -e "  ${CYAN}Max Bandwidth:${NC} $BW_READABLE ($MAX_BANDWIDTH_BPS bps)"
    echo ""

    # ИСПРАВЛЕНО: API endpoint по умолчанию api.frkn.org
    read -p "API Endpoint [https://api.frkn.org]: " API_ENDPOINT
    API_ENDPOINT=${API_ENDPOINT:-"https://api.frkn.org"}

    read -p "API Token [mysecrettoken]: " API_TOKEN
    API_TOKEN=${API_TOKEN:-"mysecrettoken"}

    FNODE_URL="https://github.com/frkn-dev/fcore/releases/download/$FNODE_VERSION/node-$ARCH"
    FNODE_CONFIG_PATH="$INSTALL_DIR/config.toml"

    ZMQ_ENDPOINT="${ZMQ_ENDPOINT:-tcp://localhost:3000}"
    METRICS_ZMQ_ENDPOINT="${METRICS_ZMQ_ENDPOINT:-tcp://localhost:3000}"
    ENV="experimental"

    mkdir -p "$INSTALL_DIR/snapshots"
    cd "$INSTALL_DIR"

    echo "Installing fnode version $FNODE_VERSION..."
    curl -L -o fnode "$FNODE_URL"
    chmod +x fnode

    # Автоматическое определение интерфейса и IP
    default_interface=$(ip route | grep '^default' | awk '{print $5}' | head -n 1)

    if [[ -n "$default_interface" ]]; then
        default_ip=$(ip -o -4 addr show dev "$default_interface" | awk '{print $4}' | cut -d'/' -f1 | head -n 1)
        print_info "Обнаружен интерфейс: $default_interface"
        print_info "Обнаружен IP адрес: $default_ip"

        read -p "Использовать автоматически определенный интерфейс и IP? (Y/n): " use_default
        if [[ "$use_default" =~ ^[Nn] ]]; then
            read -p "Введите интерфейс (например eth0): " INTERFACE
            read -p "Введите IP адрес: " ADDRESS
        else
            INTERFACE="$default_interface"
            ADDRESS="$default_ip"
        fi
    else
        print_warning "Не удалось определить интерфейс по умолчанию"
        read -p "Введите интерфейс (например eth0): " INTERFACE
        read -p "Введите IP адрес: " ADDRESS
    fi

    # Получение hostname
    CURRENT_HOSTNAME=$(hostname)
    read -p "Hostname [${CURRENT_HOSTNAME}]: " HOSTNAME
    HOSTNAME=${HOSTNAME:-$CURRENT_HOSTNAME}

    # Создание конфига
    cat <<EOF | tee "$FNODE_CONFIG_PATH" > /dev/null
[service]
snapshot_interval = 60
snapshot_path = "snapshots/snapshot-agent.bin"
log_velel = "debug"
updates_endpoint_zmq = "$ZMQ_ENDPOINT"

[metrics]
interval = 10
publisher = "$METRICS_ZMQ_ENDPOINT"

[xray]
enabled = false
path = "/opt/xray/xray-config.json"

[h2]
enabled = false
path = "/opt/hysteria/config.yaml"

[wg]
enabled =  false
path = "experimental/utun7.conf"

[mtproto]
enabled = false
path = "/opt/teleproxy/config.toml"

[node]
env = "$ENV"
uuid = "$NODE_UUID"
hostname = "$HOSTNAME"
default_interface = "$INTERFACE"
address = "$ADDRESS"
label = "$LABEL"
max_bandwidth_bps = $MAX_BANDWIDTH_BPS
country = "$COUNTRY"
type = "$NODE_TYPE"

[api]
endpoint = "$API_ENDPOINT"
token = "$API_TOKEN"
EOF

    # Создание systemd сервиса
    cat <<EOF | tee /etc/systemd/system/fnode.service > /dev/null
[Unit]
Description=Fnode Service
After=network.target

[Service]
Type=simple
ExecStart=$INSTALL_DIR/fnode $FNODE_CONFIG_PATH
Restart=on-failure
RestartSec=5
WorkingDirectory=$INSTALL_DIR

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable fnode

    print_success "Fnode установлен успешно!"
    echo ""
    print_header "Итоговая информация по Fnode"
    echo -e "${CYAN}UUID:${NC} $NODE_UUID"
    echo -e "${CYAN}Label:${NC} $LABEL"
    echo -e "${CYAN}Country:${NC} $COUNTRY"
    echo -e "${CYAN}Type:${NC} $NODE_TYPE"
    echo -e "${CYAN}Max Bandwidth:${NC} $BW_READABLE ($MAX_BANDWIDTH_BPS bps)"
    echo -e "${CYAN}Interface:${NC} $INTERFACE"
    echo -e "${CYAN}Address:${NC} $ADDRESS"
    echo -e "${CYAN}Hostname:${NC} $HOSTNAME"
    echo -e "${CYAN}Environment:${NC} $ENV"
    echo -e "${CYAN}API Endpoint:${NC} $API_ENDPOINT"
    echo ""
    print_info "Конфиг сохранен: $FNODE_CONFIG_PATH"
    print_info "Запустите командой: sudo systemctl start fnode"
}

# Функция установки всего
install_all() {
    print_header "Установка всех компонентов"

    read -p "Установить Xray? (y/N): " install_x
    read -p "Установить Hysteria2? (y/N): " install_h
    read -p "Установить Fnode? (y/N): " install_f

    echo ""

    [[ "$install_x" =~ ^[Yy] ]] && install_xray
    [[ "$install_h" =~ ^[Yy] ]] && install_hysteria
    [[ "$install_f" =~ ^[Yy] ]] && install_fnode

    print_success "Установка завершена!"

    # Показываем статус сервисов
    echo ""
    print_header "Статус установленных сервисов"
    for service in xray hysteria fnode; do
        if systemctl is-enabled --quiet $service 2>/dev/null; then
            echo -e "${GREEN}✓${NC} $service - установлен и включен"
        fi
    done

    echo ""
    print_info "Для запуска сервисов используйте:"
    echo "  sudo systemctl start xray"
    echo "  sudo systemctl start hysteria"
    echo "  sudo systemctl start fnode"
}

# Главное меню
show_menu() {
    print_header "FRKN Network Node Installer"
    YELLOW='\033[1;33m'
    NC='\033[0m' # No Color

    echo -e "${YELLOW}"
    cat << "EOF"
//                      __      _
//                     / _|    | |
//                    | |_ _ __| | ___ __
//      _____      _  |  _| '__| |/ / '_ \
//     |  __ \    (_) | | | |  |   <| | | |
//     | |__) | __ __ |_|_|_| _|_|\_\_| |_|
//     |  ___/ '__| \ \ / / _` |/ __| | | |
//     | |   | |  | |\ V / (_| | (__| |_| |
//     |_|___|_|  |_| \_/ \__,_|\___|\__, |
//      / ____|                       __/ |
//     | |     ___  _ __ ___  _ __   |___/_ __  _   _
//     | |    / _ \| '_ ` _ \| '_ \ / _` | '_ \| | | |
//     | |___| (_) | | | | | | |_) | (_| | | | | |_| |
//      \_____\___/|_| |_| |_| .__/ \__,_|_| |_|\__, |
//                           | |                 __/ |
//                           |_|                |___/
EOF
    echo -e "${NC}"

    echo "Выберите компоненты для установки:"
    echo ""
    echo "1) Установить Xray-core (с генерацией Reality конфига)"
    echo "2) Установить Hysteria2 (с генерацией конфига)"
    echo "3) Установить Fnode"
    echo "4) Установить ВСЕ компоненты"
    echo "5) Выход"
    echo ""
    read -p "Ваш выбор [1-5]: " choice

    case $choice in
    1)
        install_xray
        ;;
    2)
        install_hysteria
        ;;
    3)
        install_fnode
        ;;
    4)
        install_all
        ;;
    5)
        print_info "До свидания!"
        exit 0
        ;;
    *)
        print_error "Неверный выбор!"
        exit 1
        ;;
    esac
}

# Основная функция
main() {
    check_root
    check_os
    install_dependencies
    show_menu
}

# Запуск
main